# --- DOMAINS ---
# Your Caddy configuration will automatically fetch HTTPS certificates for these domains.
ADMIN_DOMAIN=admin.yourdomain.com
API_DOMAIN=api.yourdomain.com

# --- AUTHENTICATION ---
# A strong, random string used to sign JSON Web Tokens for Admin login
JWT_SECRET=super-secret-jwt-key-change-me-in-production

# --- CLOUDINARY (Media Storage) ---
# Your Cloudinary credentials for storing restaurant thumbnails and 3D .glb models
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- POSTGRES DATABASE ---
# This matches the internal postgres service defined in docker-compose.yml.
# If you are using an external managed database, change this URL.
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/ar_menu?schema=public
